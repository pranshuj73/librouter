# Copy to .env (gitignored) and fill in real values.
# docker-compose loads .env automatically; the gateway service reads these
# through ${VAR:-default} substitutions in docker-compose.yml.

# ---------------------------------------------------------------- caller key hashing
# REQUIRED. The pepper used to HMAC caller API keys before storage. If you
# rotate this, every caller_key_hash in the database becomes invalid and you
# must re-run scripts/seed_callers.py. Generate with:
#   openssl rand -hex 32
GATEWAY_KEY_HASH_PEPPER=

# ---------------------------------------------------------------- mode
# Switch to real vendors + env-backed secrets. Leave both as `mock` to keep
# the default no-credentials dev experience.
GATEWAY_PROVIDER_MODE=real
GATEWAY_SECRETS_MODE=env
# Keep this as config.dev.yaml unless you've also added real caller key_hashes
# to config.yaml (the production config has placeholder hashes). The dev caller
# key is "dev-key-do-not-use-in-prod".
GATEWAY_CONFIG=/code/config.dev.yaml

# ---------------------------------------------------------------- vendor keys
# Only set the ones you have. Any vendor whose key is missing will be skipped
# at boot (a warning is logged) and tier candidates pointing at it get
# weight 0 automatically.
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ---------------------------------------------------------------- caller seeding (local dev only)
# Plaintext keys for dev/test callers. Read by scripts/seed_callers.py.
# The seeding script hashes these (using GATEWAY_KEY_HASH_PEPPER above) and
# writes them to the callers table. Run ./scripts/setup.sh after setting these.
# Production keys must be provisioned out-of-band — never commit real keys here.
GATEWAY_SEED_KEY_DEV=dev-key-do-not-use-in-prod

# ---------------------------------------------------------------- runtime knobs
# Reproducible routing decisions for smoke testing. Comment out in real use.
# GATEWAY_RNG_SEED=42
# GATEWAY_LOG_LEVEL=INFO
