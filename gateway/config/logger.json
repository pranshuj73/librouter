{
  "level": "INFO",
  "redact": {
    "patterns": [
      "(?i)bearer\\s+[A-Za-z0-9._\\-]+",
      "sk-[A-Za-z0-9]{16,}",
      "ant-[A-Za-z0-9]{16,}",
      "gsk-[A-Za-z0-9]{16,}",
      "AIza[A-Za-z0-9_\\-]{20,}"
    ],
    "field_names": [
      "authorization",
      "api_key",
      "api-key",
      "token",
      "secret",
      "password",
      "key_hash"
    ],
    "replacement": "<redacted>"
  }
}
